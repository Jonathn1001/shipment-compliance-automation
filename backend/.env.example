# Copy to .env and adjust. .env is git-ignored; never commit real credentials.

# Postgres connection (see README for a docker run snippet).
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/shipment_compliance?schema=public"

# HTTP port
PORT=3000

# Bootstrap logger level: error | warn | info | debug | verbose
LOG_LEVEL=info

# Validation thresholds (introduced in later slices; safe to leave as defaults)
REVIEW_WINDOW_DAYS=30
WEIGHT_TOLERANCE_PCT=5

# development | test | production. OpenAPI docs (/api/docs) are served outside
# production only.
NODE_ENV=development

# Optional API auth. When set, every route requires `Authorization: Bearer <token>`;
# leave unset to run open (demo/dev default). Never commit a real token.
# API_AUTH_TOKEN=

# Rate limiting, per client IP: window (ms) and max requests per window.
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=300
