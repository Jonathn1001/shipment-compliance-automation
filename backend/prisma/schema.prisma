// Shipment Compliance Automation — Prisma schema
// Postgres is the source of truth. Native enums + jsonb + Decimal.
// Issue 01 (walking skeleton) introduces Shipment + AuditLog. Later slices add
// DocumentIngestion, ValidationIssue, ReadinessReport and their relations.

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Readiness lifecycle: CREATED → READY | NEEDS_REVIEW | BLOCKED → APPROVED.
enum ShipmentStatus {
  CREATED
  READY
  NEEDS_REVIEW
  BLOCKED
  APPROVED
}

/// Every state-changing operation appends one AuditLog row tagged with an action.
enum AuditAction {
  SHIPMENT_CREATED
  DOCUMENT_INGESTED
  FIELD_UPDATED
  VALIDATION_RUN
  REPORT_GENERATED
  STATUS_CHANGED
  SHIPMENT_APPROVED
}

/// Kind of trade document an ingestion represents.
enum DocumentType {
  COMMERCIAL_INVOICE
  PACKING_LIST
  BILL_OF_LADING
  CERTIFICATE_FORM_E
  OTHER
}

/// How the document data reached the system (no real OCR in scope — mock JSON).
enum SourceType {
  JSON
  OCR
  API
  CSV
}

/// Compliance issue severity. Drives the readiness status resolver:
/// any CRITICAL → BLOCKED; else any HIGH/MEDIUM → NEEDS_REVIEW; else READY.
enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

/// Lifecycle of a validation issue across re-validation runs. OPEN is (re)raised
/// each run; WAIVED is an accepted risk preserved across runs by (issueType,
/// field); RESOLVED marks an issue no longer raised since the last run.
enum IssueStatus {
  OPEN
  WAIVED
  RESOLVED
}

/// Snapshotted overall assessment on a readiness report.
enum ReadinessAssessment {
  READY_TO_PROCEED
  NEEDS_HUMAN_REVIEW
  BLOCKED
}

/// Canonical shipment — the single source of truth. Most fields are nullable so a
/// shipment can be created with partial data and progressively reconciled from
/// ingested documents; the validation rules flag fields that are required for
/// readiness but still missing.
model Shipment {
  id                 String         @id @default(cuid())
  shipmentReference  String
  exporter           String?
  importer           String?
  importerId         String?
  invoiceNumber      String?
  invoiceValue       Decimal?       @db.Decimal(18, 2)
  currency           String?
  goodsDescription   String?
  hsCode             String?
  countryOfOrigin    String?
  grossWeightKg      Decimal?       @db.Decimal(12, 3)
  netWeightKg        Decimal?       @db.Decimal(12, 3)
  numberOfPackages   Int?
  containerNumber    String?
  billOfLadingNumber String?
  packagingType      String?
  ispm15Certified    Boolean?
  eformCertificate   String?
  freightMode        String?
  arrivalDate        DateTime?
  currentStatus      ShipmentStatus @default(CREATED)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  auditLogs AuditLog[]
  documents DocumentIngestion[]
  issues    ValidationIssue[]
  reports   ReadinessReport[]

  // shipmentReference is intentionally NOT unique — duplicates must be able to
  // persist so the duplicate-shipment-reference validation rule can flag them.
  @@index([shipmentReference])
}

/// One ingested document attached to a shipment. `rawInput` preserves exactly
/// what the document contained (for audit); `mappedFields` is the canonical
/// projection produced by the field mapper. Both are jsonb — the raw payload is
/// intentionally freeform (no OCR), the mapped shape is the canonical subset.
model DocumentIngestion {
  id           String       @id @default(cuid())
  shipmentId   String
  shipment     Shipment     @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  documentType DocumentType
  sourceType   SourceType
  rawInput     Json
  mappedFields Json
  createdAt    DateTime     @default(now())

  @@index([shipmentId])
}

/// A classified compliance issue produced by a validation rule. `issueType` is a
/// String rule-code (NOT an enum) so the rule set stays open/closed — a new rule
/// is a new code, no schema change. Reconciled across runs by (issueType, field):
/// WAIVED survives, absent-since-last-run becomes RESOLVED, new is OPEN.
model ValidationIssue {
  id             String      @id @default(cuid())
  shipmentId     String
  shipment       Shipment    @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  issueType      String
  severity       Severity
  field          String?
  explanation    String
  suggestedAction String
  status         IssueStatus @default(OPEN)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([shipmentId, status])
  @@index([shipmentId, issueType, field])
}

/// Append-only readiness report history. Each validation run appends one row so a
/// shipment's readiness evolution is retained. Snapshotted fields freeze the
/// decision at generation time; `nextActions` is the suggested next steps list.
model ReadinessReport {
  id                 String              @id @default(cuid())
  shipmentId         String
  shipment           Shipment            @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  statusSnapshot     ShipmentStatus
  overallAssessment  ReadinessAssessment
  humanReviewRequired Boolean
  totalIssues        Int
  criticalCount      Int
  warningCount       Int
  nextActions        String[]
  generatedAt        DateTime            @default(now())

  @@index([shipmentId, generatedAt])
}

/// Append-only audit trail. Postgres does not auto-index foreign keys, so the
/// read path (by shipment, newest first) is indexed explicitly.
model AuditLog {
  id         String      @id @default(cuid())
  shipmentId String
  shipment   Shipment    @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  timestamp  DateTime    @default(now())
  action     AuditAction
  actor      String      @default("system")
  details    Json?

  @@index([shipmentId, timestamp])
}
